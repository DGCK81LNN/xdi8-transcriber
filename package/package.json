  "keywords": [
    "shidinn",
    "xdi8",
    "希顶"
  ],
  "description": "Transcribe Hanzi characters into Shidinn, a constructed language, and vice versa. 〇改希顶语字表转写模块",
  "author": "DGCK81LNN <triluolnn@163.com>",
  "license": "MIT",
  "files": [
    "lib",
    "dist"
  ],
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "browser": "dist/index.min.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DGCK81LNN/xdi8-transcriber.git"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "cross-env": "^10.1.0",
    "earl": "^2.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "globals": "^14.0.0",
    "lodash": "^4.18.1",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "directories": {
    "test": "test"
  },
  "scripts": {
    "lint": "eslint src",
    "test": "cross-env TS_NODE_PROJECT=tsconfig.test.json mocha",
    "build": "npm run build:data && npm run build:libdts && npm run build:lib",
    "build:data": "node build/data.js",
    "build:libdts": "tsc",
    "build:lib": "node build/lib.js"
  }
