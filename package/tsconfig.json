{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["es2021"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "es6",
    "rootDir": "src",
    "outDir": "lib",
    "module": "esnext",
    "moduleResolution": "bundler",
    "emitDeclarationOnly": true,
    "diagnostics": true,
    "listEmittedFiles": true
  },
  "include": ["src/**/*.ts"],
}
